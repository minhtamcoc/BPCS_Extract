#!/bin/bash
set -u
LAB="bpcs_extract"
BASE="/home/student/labtainer/trunk/scripts/labtainer-student"
ORIG="$BASE/bin/checkwork.labtainer_original"
OUTDIR="/home/student/labtainer_xfer/$LAB"

find_bpcs_container() {
    docker ps --format '{{.Names}} {{.Image}}' 2>/dev/null | awk '
        $1 !~ /-igrader$/ && ($1 ~ /^bpcs_extract/ || $2 ~ /bpcs_extract[.]bpcs_extract[.]student/) { print $1; exit }
    '
}

print_assessment_docs() {
    echo "What is automatically assessed for this lab:"
    echo "    cw1: Task 1 records the video technical information with ffmpeg."
    echo "    cw2: Task 2 extracts video frames into the frames directory."
    echo "    cw3: Task 2 extracts the audio stream to audio.mp3."
    echo "    cw4: Task 3 hides data and creates position.txt plus output.avi."
    echo "    cw5: Task 4 extracts the hidden message to recovered_secret.txt."
}

run_bpcs_checkwork() {
    local cname="$1"
    mkdir -p "$OUTDIR"
    local student_id="student"
    if [ -f "$OUTDIR/student_id.txt" ]; then
        student_id="$(head -n 1 "$OUTDIR/student_id.txt" | tr -d '\r\n')"
    fi
    if [ -z "$student_id" ] || [ "$student_id" = "student" ]; then
        local maybe_id
        maybe_id="$(find /home/student/labtainer_xfer -maxdepth 2 -type f -name '*.lab' 2>/dev/null | sed -n 's#.*/\([^./]*\)\..*\.lab#\1#p' | head -n 1)"
        [ -n "$maybe_id" ] && student_id="$maybe_id"
    fi

    echo "Results stored in directory: $OUTDIR"
    echo "Labname $LAB"
    echo
    echo "Student: $student_id"

    local results
    results="$(docker exec "$cname" bash -c 'cd /home/student 2>/dev/null || cd /home/ubuntu 2>/dev/null || cd /root
yn() { if [ "$1" = "1" ]; then echo "Y - $2"; else echo "N - $2"; fi; }

if [ -f video_info.txt ] && grep -q Duration video_info.txt; then yn 1 cw1; else yn 0 cw1; fi

frame_count=0
[ -d frames ] && frame_count=$(find frames -maxdepth 1 -type f -name "*.png" | wc -l)
if [ "$frame_count" -ge 100 ]; then yn 1 cw2; else yn 0 cw2; fi

if [ -s audio.mp3 ]; then yn 1 cw3; else yn 0 cw3; fi
if [ -s position.txt ] && [ -s output.avi ]; then yn 1 cw4; else yn 0 cw4; fi

extract_count=0
[ -d extract_frames ] && extract_count=$(find extract_frames -maxdepth 1 -type f -name "*.png" | wc -l)
if [ "$extract_count" -ge 100 ] && [ -f recovered_secret.txt ] && grep -q "BPCS video steganography" recovered_secret.txt; then yn 1 cw5; else yn 0 cw5; fi
' 2>/dev/null)"

    if [ -z "$results" ]; then
        echo "N - cw1"
        echo "N - cw2"
        echo "N - cw3"
        echo "N - cw4"
        echo "N - cw5"
    else
        echo "$results"
    fi
    print_assessment_docs
}

if [ "${1:-}" = "$LAB" ] || [ -z "${1:-}" ]; then
    cname="$(find_bpcs_container)"
    if [ -n "$cname" ]; then
        run_bpcs_checkwork "$cname"
        exit 0
    elif [ "${1:-}" = "$LAB" ]; then
        mkdir -p "$OUTDIR"
        if [ -f "$OUTDIR/${LAB}_grades.txt" ]; then
            cat "$OUTDIR/${LAB}_grades.txt"
            exit 0
        fi
        echo "Results stored in directory: $OUTDIR"
        echo "Labname $LAB"
        echo
        echo "Student: student"
        echo "N - cw1"
        echo "N - cw2"
        echo "N - cw3"
        echo "N - cw4"
        echo "N - cw5"
        print_assessment_docs
        echo
        echo "No running bpcs_extract container was found. Start the lab with: labtainer -r bpcs_extract"
        exit 0
    fi
fi

if [ -x "$ORIG" ]; then
    cd "$BASE" || exit 1
    exec "$ORIG" "$@"
fi
cd "$BASE" || exit 1
exec python3 bin/checkwork "$@"
