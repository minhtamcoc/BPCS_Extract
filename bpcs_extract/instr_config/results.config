# Five Labtainer grading checks for bpcs_extract.

# DOC: Task 1 records the video technical information with ffmpeg.
cw1_video_info = ./video_info.txt : CONTAINS : Duration

# DOC: Task 2 extracts video frames into the frames directory.
cw2_frames = ./.bash_history : CONTAINS : frames/frame_%04d.png

# DOC: Task 3 extracts the audio stream to audio.mp3.
cw3_audio = ./.bash_history : CONTAINS : audio.mp3

# DOC: Task 4 hides data and creates position.txt plus output.avi.
cw4_position = python3.stdout : CONTAINS : POSITION_FILE_WRITTEN

# DOC: Task 5 extracts the hidden message to recovered_secret.txt.
cw5_decode = python3.stdout : CONTAINS : BPCS_DECODE_SUCCESS
cw5_secret = ./recovered_secret.txt : CONTAINS : BPCS video steganography
