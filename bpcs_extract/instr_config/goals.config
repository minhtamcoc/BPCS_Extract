# goals.config
#
# DOC: Task 1 records the video technical information with ffmpeg.
cw1 = is_true : _video_info_checked
# DOC: Task 2 extracts video frames into the frames directory.
cw2 = is_true : _frames_extracted
# DOC: Task 2 extracts the audio stream to audio.mp3.
cw3 = is_true : _audio_extracted
# DOC: Task 3 hides data and creates position.txt.
cw4 = is_true : _position_created
# DOC: Task 4 extracts the hidden message to recovered_secret.txt.
cw5 = is_true : _bpcs_decoded
